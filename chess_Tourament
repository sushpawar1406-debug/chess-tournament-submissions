SELECT
t.TournamentName,
p.PlayerName
FROM TournamentPlayers tp
JOIN Players p
ON tp.PlayerID=p.PlayerID
JOIN Tournaments t
ON tp.TournamentID=t.TournamentID;

SELECT PlayerID
FROM TournamentPlayers
WHERE TournamentID=1
ORDER BY RANDOM();

SELECT
CASE
WHEN ABS(RANDOM()) % 2 = 0
THEN Player1ID
ELSE Player2ID
END AS WinnerID
FROM
(
SELECT 3 AS Player1ID,
       1 AS Player2ID
);

