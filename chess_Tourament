SELECT
m.MatchID,
p1.PlayerName AS Player1,
p2.PlayerName AS Player2,
w.PlayerName AS Winner
FROM Matches m
JOIN Players p1
ON m.Player1ID=p1.PlayerID
JOIN Players p2
ON m.Player2ID=p2.PlayerID
JOIN Players w
ON m.WinnerID=w.PlayerID;


SELECT
p.PlayerID,
p.PlayerName,
COUNT(m.WinnerID) AS TotalWins
FROM Players p
LEFT JOIN Matches m
ON p.PlayerID=m.WinnerID
GROUP BY
p.PlayerID,
p.PlayerName
ORDER BY TotalWins DESC;


SELECT
p.PlayerName,
COUNT(m.WinnerID) AS Wins
FROM Players p
LEFT JOIN Matches m
ON p.PlayerID=m.WinnerID
GROUP BY
p.PlayerID,
p.PlayerName
ORDER BY Wins DESC
LIMIT 3;
